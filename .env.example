# required
PIN_LOCK=0000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-secret-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# recommended — high-entropy secret mixed into the unlock cookie's HMAC key
# (falls back to SUPABASE_SECRET_KEY when unset; rotating it logs out every
# device, same as rotating PIN_LOCK)
SESSION_SECRET=

# optional — overrides the food-AI model (defaults to claude-sonnet-5)
ANTHROPIC_FOOD_MODEL=
# optional — voice transcription only; every other capture mode works without it
OPENAI_API_KEY=
# optional — USDA text search (falls back to DEMO_KEY rate limits)
USDA_API_KEY=
# optional — daily cap on food-AI calls (default 60; 0 disables the cap)
AI_DAILY_CAP=
# optional — set to 1 to expose the /design gallery in production
DESIGN_GALLERY=
